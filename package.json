{
  "name": "diff-split",
  "version": "0.1.0",
  "description": "Portable git-based CLI to split monorepo diffs into independent PR branches",
  "type": "module",
  "bin": {
    "diff-split": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.tsx",
    "lint": "oxlint --ignore-path .gitignore .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "changeset": "changeset",
    "release": "changeset publish"
  },
  "keywords": [
    "git",
    "monorepo",
    "cli",
    "changes",
    "pull-request"
  ],
  "author": "",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "ink": "^5.2.1",
    "react": "^18.3.1",
    "tinyglobby": "^0.2.15"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^24.7.2",
    "@types/react": "^18.3.17",
    "oxlint": "^1.22.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.3"
  }
}
